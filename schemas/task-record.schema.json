{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:proofrail:schemas:task-record",
  "title": "TaskRecord",
  "description": "Durable task contract planned for the OpenClaw-first workflow runtime.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "status",
    "plan",
    "artifacts",
    "needsUserInput",
    "needsApproval"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "in_progress",
        "blocked",
        "review",
        "done"
      ]
    },
    "plan": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "needsUserInput": {
      "type": "boolean"
    },
    "needsApproval": {
      "type": "boolean"
    },
    "summary": {
      "type": "string"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}