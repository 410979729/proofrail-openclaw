{
  "id": "proofrail",
  "name": "Proofrail for OpenClaw",
  "description": "Proofrail for OpenClaw: execution harness, runtime guardrails, evidence-first changes, and verification gates for OpenClaw agents.",
  "version": "0.0.1",
  "kind": "tool",
  "enabledByDefault": false,
  "activation": {
    "onStartup": true,
    "onCapabilities": [
      "hook"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "dangerousCommandAction": {
        "type": "string",
        "enum": [
          "approve",
          "block"
        ],
        "default": "approve"
      },
      "summaryThresholdChars": {
        "type": "integer",
        "minimum": 1000,
        "maximum": 50000,
        "default": 8000
      },
      "lowSignalBlockThreshold": {
        "type": "integer",
        "minimum": 1,
        "maximum": 20,
        "default": 2
      }
    }
  }
}
